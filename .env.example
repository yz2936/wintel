# OpenAI API key used by the backend and Vercel serverless function.
OPENAI_API_KEY="your_openai_api_key_here"

# Optional override. Defaults to gpt-5.2-chat-latest.
OPENAI_MODEL="gpt-5.2-chat-latest"

# Optional local backend port for `npm run server`.
API_PORT="3001"

# Public browser env vars for Supabase auth/session access.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"

# Server env vars for Vercel API token verification.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your_supabase_anon_key"

# Optional server-only admin key if you want privileged Supabase access later.
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# Docket watch cron and email delivery.
DOCKET_SYNC_SECRET="set_a_long_random_secret_for_manual_syncs"
RESEND_API_KEY="your_resend_api_key"
DOCKET_ALERT_FROM_EMAIL="Wintel Alerts <alerts@yourdomain.com>"
DOCKET_ALERT_REPLY_TO_EMAIL="team@yourdomain.com"
