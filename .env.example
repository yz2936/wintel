# OpenAI API key used by the backend and Vercel serverless function.
OPENAI_API_KEY="your_openai_api_key_here"

# Optional override. Defaults to gpt-5.2-chat-latest.
OPENAI_MODEL="gpt-5.2-chat-latest"

# Optional local backend port for `npm run server`.
API_PORT="3001"

# Optional Vercel KV REST credentials for production persistence.
# When unset, local development falls back to SQLite in `data/wintel.db`.
KV_REST_API_URL="https://your-kv-endpoint.upstash.io"
KV_REST_API_TOKEN="your_vercel_kv_rest_token"
